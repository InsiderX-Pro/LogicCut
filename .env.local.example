# Copy this file to .env.local and fill only the values you need.
# Never commit .env.local, cookies, API keys, tokens, or model weights.

# Hugging Face gated models, required by pyannote full profile.
HF_TOKEN=

# Optional Bilibili cookies file for deeper comment screenshots.
BILIBILI_COOKIES=

# LogicCut output/cache paths.
LOGICCUT_OUTPUT_DIR=output
LOGICCUT_MODELS_DIR=model_cache

# Video translation backend.
LOGICCUT_VIDEO_TRANSLATION_BACKEND=video-translate-refine
LOGICCUT_SOURCE_LANGUAGE=en
LOGICCUT_TARGET_LANGUAGE=中文

# TTS service selection.
LOGICCUT_TTS_ENGINE=indextts2
LOGICCUT_TTS_PORTS=8304

# Optional local service ports.
LOGICCUT_FISH_TTS_ADAPTER_URL=http://127.0.0.1:8392
